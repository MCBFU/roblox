local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local localPlayer = Players.LocalPlayer

StarterGui:SetCore("SendNotification", {
    Title = "Made by XQ",
    Text = "感谢使用 XQ 作品",
    Icon = "rbxassetid://120172811078080",
    Duration = 5
})

StarterGui:SetCore("SendNotification", {
    Title = "皮肤解锁",
    Text = "正在解锁怪物皮肤...",
    Icon = "rbxassetid://120172811078080",
    Duration = 6
})

local playerData = localPlayer:WaitForChild("PlayerData")
local customization = playerData:WaitForChild("Customization")
local monster = customization:WaitForChild("Monster")
local characters = {"Boxy", "Huggy", "Mommy", "Stalky"}

local totalMonsterUnlocked = 0

for _, charName in ipairs(characters) do
    local character = monster:FindFirstChild(charName)
    if character then
        local inventory = character:FindFirstChild("Inventory")
        if inventory then
            for _, skin in ipairs(inventory:GetChildren()) do
                if skin:IsA("BoolValue") and skin.Value == false then
                    skin.Value = true
                    totalMonsterUnlocked = totalMonsterUnlocked + 1
                end
            end
        end
    end
end

task.wait(0.5)
StarterGui:SetCore("SendNotification", {
    Title = "怪物皮肤解锁完成",
    Text = "共解锁 "..totalMonsterUnlocked.." 个皮肤",
    Icon = "rbxassetid://120172811078080",
    Duration = 4
})

task.wait(0.5)
StarterGui:SetCore("SendNotification", {
    Title = "皮肤解锁",
    Text = "正在解锁幸存者皮肤...",
    Icon = "rbxassetid://120172811078080",
    Duration = 6
})

local survivor = customization:FindFirstChild("Survivor")
if survivor then
    local inventory = survivor:FindFirstChild("Inventory")
    if inventory then
        local totalSurvivorUnlocked = 0
        local parts = {"Hats", "Grabpacks", "Hands", "Shirts", "Shoes", "Pants"}

        for _, partName in ipairs(parts) do
            local partFolder = inventory:FindFirstChild(partName)
            if partFolder then
                for _, skin in ipairs(partFolder:GetChildren()) do
                    if skin:IsA("BoolValue") and skin.Value == false then
                        skin.Value = true
                        totalSurvivorUnlocked = totalSurvivorUnlocked + 1
                    end
                end
            end
        end

        task.wait(0.5)
        StarterGui:SetCore("SendNotification", {
            Title = "幸存者皮肤解锁完成",
            Text = "共解锁 "..totalSurvivorUnlocked.." 个皮肤",
            Icon = "rbxassetid://120172811078080",
            Duration = 4
        })
        
        task.wait(0.5)
        StarterGui:SetCore("SendNotification", {
            Title = "全部解锁完成",
            Text = "怪物: "..totalMonsterUnlocked.." | 幸存者: "..totalSurvivorUnlocked,
            Icon = "rbxassetid://120172811078080",
            Duration = 6
        })
    else
        warn("未找到幸存者的 Inventory 文件夹")
    end
else
    warn("未找到 Survivor 文件夹")
end